{
  "$schema": "https://raw.githubusercontent.com/sumneko/lua-language-server/master/setting/schema.json",
  "diagnostics": {
    "disable": [
      "lowercase-global"
    ],
    "globals": [
      "SYSTEM",
      "ZOI",
      "PKG",
      "BUILD_DIR",
      "STAGING_DIR",
      "BUILD_TYPE",
      "SUBPKG",
      "metadata",
      "dependencies",
      "updates",
      "hooks",
      "service",
      "prepare",
      "package",
      "verify",
      "test",
      "uninstall",
      "cmd",
      "zcp",
      "zln",
      "zchmod",
      "zchown",
      "zmkdir",
      "zrm",
      "IMPORT",
      "INCLUDE",
      "verifyHash",
      "verifySignature",
      "addPgpKey",
      "UTILS"
    ]
  },
  "runtime": {
    "version": "Luau"
  },
  "workspace": {
    "checkThirdParty": false,
    "library": [
      "~/.zoi/lsp"
    ]
  }
}
